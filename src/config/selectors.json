{
  "version": 3,
  "whatsapp": {
    "composer": [
      "footer div[contenteditable='true'][data-tab]",
      "div[contenteditable='true'][data-tab='10']",
      "footer [role='textbox'][contenteditable='true']"
    ],
    "captionInput": [
      "div[aria-label='Add a caption'][contenteditable='true']",
      "div[contenteditable='true'][aria-placeholder='Add a caption']",
      "div.copyable-area div[contenteditable='true'][data-tab][role='textbox']"
    ],
    "mediaPreview": [
      "div[data-animate-media-preview]",
      "span[data-icon='send']",
      "div[aria-label='Send']"
    ]
  },
  "telegram": {
    "composer": [
      ".input-message-input[contenteditable='true']",
      "div[contenteditable='true'].input-message-input",
      ".composer_rich_textarea[contenteditable='true']"
    ],
    "captionInput": [
      ".popup.active .input-message-input[contenteditable='true']",
      ".popup-send-photo .input-message-input",
      ".popup .input-field-input[contenteditable='true']"
    ],
    "mediaPreview": [
      ".popup-send-photo",
      ".popup.popup-new-media",
      ".popup .btn-primary"
    ]
  }
}
